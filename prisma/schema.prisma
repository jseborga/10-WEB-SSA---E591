generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                String   @id @default(cuid())
  title             String
  titleEn           String?
  titlePt           String?
  description       String?
  descriptionEn     String?
  descriptionPt     String?
  fullDescription   String?
  fullDescriptionEn String?
  fullDescriptionPt String?
  category          String
  location          String?
  year              Int?
  area              String?
  featured          Boolean  @default(false)
  showOnHomepage    Boolean  @default(false)
  published         Boolean  @default(false)
  publishedAt       DateTime?
  mainImage         String?
  mainImageMobile   String?
  gallery           String?
  galleryMobile     String?
  videoUrl          String?
  client            String?
  status            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Publication {
  id          String   @id @default(cuid())
  title       String
  titleEn     String?
  titlePt     String?
  slug        String   @unique
  excerpt     String?
  excerptEn   String?
  excerptPt   String?
  content     String?
  contentEn   String?
  contentPt   String?
  image       String?
  seoTitle    String?
  seoDescription String?
  seoKeywords String?
  published   Boolean  @default(false)
  showInMenu  Boolean  @default(false)
  menuOrder   Int      @default(0)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id          String   @id @default(cuid())
  sessionId   String
  name        String
  email       String?
  message     String
  isFromAdmin Boolean  @default(false)
  isFromAI    Boolean  @default(false)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model LeadCapture {
  id               String   @id @default(cuid())
  sessionId        String   @unique
  source           String   @default("chat-web")
  name             String?
  email            String?
  phone            String?
  telegramHandle   String?
  preferredContactChannel String?
  contactConsent   Boolean  @default(false)
  contactConsentAt DateTime?
  serviceType      String?
  projectType      String?
  projectLocation  String?
  projectIdea      String?
  summary          String?
  lastVisitorMessage String?
  leadStatus       String   @default("new")
  priority         String   @default("normal")
  ownerName        String?
  nextAction       String?
  nextFollowUpAt   DateTime?
  lastContactedAt  DateTime?
  internalNotes    String?
  needsHuman       Boolean  @default(false)
  qualified        Boolean  @default(false)
  telegramNotified Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String?
  passwordHash String
  role         String   @default("editor")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id           String   @id @default(cuid())
  companyName  String   @default("SSA Ingenieria")
  legalName    String?
  tagline      String?
  siteUrl      String?
  seoTitle     String?
  seoDescription String?
  seoKeywords  String?
  logoUrl      String?
  faviconUrl   String?
  socialShareImageUrl String?
  heroImages   String?
  heroImagesMobile     String?
  heroImageOpacity    Int      @default(34)
  heroImageSaturation Int      @default(90)
  heroImageBrightness Int      @default(100)
  heroImageContrast   Int      @default(105)
  heroImageFit        String   @default("cover")
  heroImageTreatment  String   @default("original")
  heroShowCompanyName Boolean  @default(false)
  heroTextTone        String   @default("dark")
  projectCategories   String?
  email        String?
  phone        String?
  whatsapp     String?
  addressLine  String?
  city         String?
  country      String?
  footerText   String?
  instagramUrl String?
  facebookUrl  String?
  linkedinUrl  String?
  youtubeUrl   String?
  tiktokUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TelegramConfig {
  id                   String   @id @default(cuid())
  enabled              Boolean  @default(false)
  botToken             String?
  botUsername          String?
  webhookUrl           String?
  webhookSecret        String?
  allowedUserIds       String?
  allowedChatIds       String?
  autoCreateReviews    Boolean  @default(true)
  autoApproveKnownUsers Boolean @default(false)
  defaultProjectCategory String? @default("telegram")
  defaultProjectStatus String? @default("received")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model TelegramIdentity {
  id             String   @id @default(cuid())
  telegramUserId String   @unique
  username       String?
  firstName      String?
  lastName       String?
  isAllowed      Boolean  @default(false)
  lastSeenAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TelegramConversation {
  id             String   @id @default(cuid())
  telegramUserId String   @unique
  chatId         String
  flowType       String?
  step           String?
  status         String   @default("idle")
  draftData      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MediaAsset {
  id                String   @id @default(cuid())
  source            String   @default("manual")
  kind              String
  fileName          String
  originalName      String?
  mimeType          String?
  size              Int?
  url               String
  storagePath       String?
  telegramFileId    String?
  telegramMessageId String?
  telegramChatId    String?
  telegramUserId    String?
  status            String   @default("ready")
  metadata          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ApprovalItem {
  id              String   @id @default(cuid())
  source          String   @default("manual")
  entityType      String
  entityId        String?
  status          String   @default("pending")
  title           String
  summary         String?
  details         String?
  payload         String?
  requestedByType String?
  requestedById   String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AutomationLog {
  id         String   @id @default(cuid())
  source     String
  eventType  String
  status     String
  actorType  String?
  actorId    String?
  entityType String?
  entityId   String?
  summary    String
  payload    String?
  createdAt  DateTime @default(now())
}

model ChatConfig {
  id                String   @id @default(cuid())
  enabled           Boolean  @default(false)
  provider          String   @default("default")
  apiKey            String?
  apiBaseUrl        String?
  model             String?
  imageProvider     String   @default("google")
  imageApiKey       String?
  imageApiBaseUrl   String?
  imageModel        String?
  imagePrompt       String?
  systemPrompt      String
  systemPromptEn    String?
  systemPromptPt    String?
  welcomeMessage    String?
  welcomeMessageEn  String?
  welcomeMessagePt  String?
  fallbackMessage   String?
  fallbackMessageEn String?
  fallbackMessagePt String?
  companyName       String   @default("estudio591")
  companyInfo       String?
  companyInfoEn     String?
  companyInfoPt     String?
  temperature       Float    @default(0.7)
  maxTokens         Int      @default(1000)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
